


{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "1 - Compile sqlite3",
      "type": "shell",
      "command": "C:\\Qt\\Tools\\mingw1310_64\\bin\\gcc.exe",
      "args": [
        "-c",
        "${workspaceFolder}\\sqlite3.c",
        "-o",
        "${workspaceFolder}\\sqlite3.o",
        "-I",
        "${workspaceFolder}\\include"
      ],
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "2 - Run MOC on mainwindow.h",
      "type": "shell",
      "command": "C:\\Qt\\6.11.0\\mingw_64\\bin\\moc.exe",
      "args": [
        "${workspaceFolder}\\include\\mainwindow.h",
        "-o",
        "${workspaceFolder}\\moc_mainwindow.cpp",
        "-I",
        "${workspaceFolder}\\include",
        "-I",
        "C:\\Qt\\6.11.0\\mingw_64\\include",
        "-I",
        "C:\\Qt\\6.11.0\\mingw_64\\include\\QtWidgets",
        "-I",
        "C:\\Qt\\6.11.0\\mingw_64\\include\\QtGui",
        "-I",
        "C:\\Qt\\6.11.0\\mingw_64\\include\\QtCore"
      ],
      "group": "build",
      "dependsOn": "1 - Compile sqlite3",
      "problemMatcher": []
    },
    {
      "label": "3 - Build Library System",
      "type": "shell",
      "command": "C:\\Qt\\Tools\\mingw1310_64\\bin\\g++.exe",
      "args": [
        "-std=c++17",
        "-o",
        "${workspaceFolder}\\main.exe",
        "${workspaceFolder}\\src\\main.cpp",
        "${workspaceFolder}\\GUI\\mainwindow.cpp",
        "${workspaceFolder}\\moc_mainwindow.cpp",
        "${workspaceFolder}\\src\\book.cpp",
        "${workspaceFolder}\\src\\library.cpp",
        "${workspaceFolder}\\src\\database.cpp",
        "${workspaceFolder}\\src\\user.cpp",
        "${workspaceFolder}\\src\\fine.cpp",
        "${workspaceFolder}\\src\\reservation.cpp",
        "${workspaceFolder}\\src\\reportmanger.cpp",
        "${workspaceFolder}\\sqlite3.o",
        "-I",
        "${workspaceFolder}\\include",
        "-I",
        "C:\\Qt\\6.11.0\\mingw_64\\include",
        "-I",
        "C:\\Qt\\6.11.0\\mingw_64\\include\\QtWidgets",
        "-I",
        "C:\\Qt\\6.11.0\\mingw_64\\include\\QtGui",
        "-I",
        "C:\\Qt\\6.11.0\\mingw_64\\include\\QtCore",
        "-L",
        "C:\\Qt\\6.11.0\\mingw_64\\lib",
        "-lQt6Widgets",
        "-lQt6Gui",
        "-lQt6Core",
        "-Wno-deprecated-declarations"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": "2 - Run MOC on mainwindow.h",
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "4 - Run",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "set PATH=C:\\Qt\\6.11.0\\mingw_64\\bin;C:\\Qt\\Tools\\mingw1310_64\\bin;%PATH% && ${workspaceFolder}\\main.exe"
      ],
      "group": "test",
      "dependsOn": "3 - Build Library System"
    }
  ]
}